diff --git a/scripts/hkey-populate.sh b/scripts/hkey-populate.sh
index 17c74af..1dcbb22 100755
--- a/scripts/hkey-populate.sh
+++ b/scripts/hkey-populate.sh
@@ -9,17 +9,27 @@
 #   HKEY_SELF_SIGNED     set to "true" to accept self-signed TLS
 #   HKEY_MASTERKEY_PASS  passphrase for the root master key
 #   HKEY_ADMIN_PASS      admin user password
-#   HKEY_BIN             path to hkey binary (default: ./target/debug/hkey)
+#   HKEY_BIN             path to hkey binary (default: ./target/release/hkey)
 #
 # The script is fully idempotent: re-running it is safe.
 set -euo pipefail
 
+if [ -z "./hierarkey-config.toml" ]; then
+  echo "Error: hierarkey-config.toml not found in current directory." >&2
+  exit 1
+fi
+
+if [ -z "./target/release" ]; then
+  echo "Error: target/release directory not found. Please build the project first." >&2
+  exit 1
+fi
+
 # ─── Config ──────────────────────────────────────────────────────────────────
 SERVER_URL="${HKEY_SERVER_URL:-http://127.0.0.1:9090}"
 SELF_SIGNED="${HKEY_SELF_SIGNED:-false}"
 MASTERKEY_PASS="${HKEY_MASTERKEY_PASS:-masterkeypassphrase}"
 ADMIN_PASS="${HKEY_ADMIN_PASS:-adminadminadmin}"
-HKEY_BIN="${HKEY_BIN:-./target/debug/hkey}"
+HKEY_BIN="${HKEY_BIN:-./target/release/hkey}"
 KEYDIR="${KEYDIR:-./.hkey-populate-keys}"
 
 # ─── Base command array ───────────────────────────────────────────────────────
